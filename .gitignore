# Local .terraform directory (huge folder, no need to 
push)
**/.terraform/*

# .tfstate files (Contains secrets and current infra 
status)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (These usually contain 
secrets/passwords)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Mac specific files
.DS_Store
